# Discord webhook URL for alerts (optional)
DISCORD_WEBHOOK_URL=

# Subnets to scan for miners (comma-separated)
SCAN_SUBNETS=192.168.60.0/24

# Poll interval in seconds (how often to fetch metrics from each device)
POLL_INTERVAL=30

# Scan interval in seconds (how often to scan subnets for new devices)
SCAN_INTERVAL=300

# Days of metric history to retain
DATA_RETENTION_DAYS=365

# Backend URL as seen from inside the frontend container.
# Default works when both services are on the same Docker Compose network.
# Override if you rename the backend service or use separate networks:
# BITSCOPE_BACKEND_URL=http://192.168.1.50:8000
BITSCOPE_BACKEND_URL=http://backend:8000
