# BitScope Configuration
# Copy this to .env and fill in your values

# Discord webhook URL for alerts (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Comma-separated subnets to scan
SCAN_SUBNETS=192.168.60.0/24

# How often to poll each device (seconds)
POLL_INTERVAL=30

# How often to scan for new devices (seconds)
SCAN_INTERVAL=300

# How many days of metrics to keep
DATA_RETENTION_DAYS=365
